#
# {{ ansible_managed }}
#
{% for section in item.sections %}

[{{ section.name }}]
{% for key, value in section.settings.items() %}
{% if value is iterable and value is not string %}
{% for v in value %}
{{ key }}={{ v }}
{% endfor %}
{% else %}
{{ key }}={{ value }}
{% endif %}
{% endfor %}
{% endfor %}
